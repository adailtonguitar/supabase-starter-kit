# Copie para .env e preencha com os valores em:
# Supabase → Project Settings → API

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ============================================================
# Secrets das Edge Functions (configure no painel Supabase em:
# Project Settings → Edge Functions → Secrets).
# NÃO coloque no .env do frontend — apenas para referência.
# ============================================================

# Envio de e-mail transacional (já em uso)
# RESEND_API_KEY=re_...
# ERROR_NOTIFICATION_EMAIL=contato@anthosystem.com.br

# Alertas externos (todos opcionais — canais não configurados são pulados)
# ALERT_DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/.../...
# ALERT_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/.../.../...
# ALERT_TELEGRAM_BOT_TOKEN=1234567890:ABCdefGhIJKLmnoPQRstuVWXyz
# ALERT_TELEGRAM_CHAT_ID=-1001234567890
# ALERT_MIN_SEVERITY=warning   # info | warning | critical (default: warning)
